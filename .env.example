# ====================================
# NETLIFY — Site settings → Environment variables
# ====================================
# Required for the AI match function
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ====================================
# RAILWAY — Variables tab
# ====================================
# Comma-separated list of allowed origins (your Netlify domain)
# Use "*" only during local dev
ALLOWED_ORIGIN=https://your-app.netlify.app

# Railway provides PORT automatically; only set if running locally
# PORT=3000

# Optional: override DB file path
# DB_FILE=/data/db.json
